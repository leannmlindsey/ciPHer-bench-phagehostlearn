# phagehostlearn_delta.env — NCSA Delta paths
#
# Pre-run: unzip ciPHer-bench-phagehostlearn-data.zip into <repo>/data/
#   cd /projects/bfzj/llindsey1/PHI_TSP/ciPHer-comparisons/phagehostlearn/data
#   unzip ciPHer-bench-phagehostlearn-data.zip

export PHL_DATA_DIR=/projects/bfzj/llindsey1/PHI_TSP/ciPHer-comparisons/phagehostlearn/data

# Derived (layout mirrors laptop)
export PHL_REPO=${PHL_DATA_DIR}/PhageHostLearn
export CIPHER_REPO=${PHL_DATA_DIR}/cipher
export CIPHER_VAL_GENOMES=${PHL_DATA_DIR}/cipher_val_genomes
export PHL_OUTPUT_ROOT=${PHL_DATA_DIR}/_predictions

export PHL_CONDA_ENV=phagehostlearn

# DeltaAI GPU partition (no CPU allocation in our bfzj account)
export ACCOUNT=bfzj-dtai-gh
export PARTITION=ghx4
export GPUS_PER_NODE=1
